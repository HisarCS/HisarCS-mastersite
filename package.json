{
  "name": "hisarcs-mastersite",
  "private": true,
  "scripts": {
    "dev": "serve -l 3000 .",
    "stack": "supabase start --network-id local-network",
    "stack:down": "supabase stop --no-backup",
    "stack:reset": "npm run stack:down && npm run stack",
    "test": "playwright test -c tests/playwright.config.js",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test:unit",
    "db:push": "supabase db push"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.56.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "serve": "^14.2.0",
    "supabase": "^2.108.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
